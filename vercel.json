{
    "version": 2,
    "builds": [
        {
            "src": "main.py",
            "use": "@vercel/python"
        },
        {
            "src": "Frontend/*.{html,js,css}",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(health|predict|docs|openapi.json)",
            "dest": "/main.py"
        },
        {
            "src": "/",
            "dest": "/Frontend/index.html"
        },
        {
            "src": "/(.*)",
            "dest": "/Frontend/$1"
        }
    ]
}
